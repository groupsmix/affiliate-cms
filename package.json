{
  "name": "affiliate-cms",
  "version": "1.0.0",
  "description": "Supabase-backed affiliate content site CMS",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages",
    "start": "next start",
    "deploy": "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name affiliate-cms",
    "preview": "npm run build:cf && wrangler pages dev .vercel/output/static",
    "typecheck": "tsc --noEmit",
    "build:cli": "tsc -p tsconfig.cli.json",
    "admin:categories": "tsx src/admin/categories.ts",
    "admin:products": "tsx src/admin/products.ts",
    "admin:content": "tsx src/admin/content.ts",
    "admin:content-products": "tsx src/admin/content-products.ts",
    "migrate": "tsx src/lib/migrate.ts"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.15",
    "@supabase/supabase-js": "^2.45.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "marked": "^17.0.4",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.75.0"
  }
}
