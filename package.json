{
  "name": "affiliate-cms",
  "version": "1.0.0",
  "description": "Supabase-backed affiliate content site CMS",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "build:cli": "tsc -p tsconfig.cli.json",
    "admin:categories": "tsx src/admin/categories.ts",
    "admin:products": "tsx src/admin/products.ts",
    "admin:content": "tsx src/admin/content.ts",
    "admin:content-products": "tsx src/admin/content-products.ts",
    "migrate": "tsx src/lib/migrate.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
